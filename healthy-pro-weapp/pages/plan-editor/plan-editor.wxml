<view class="page">
  <view class="eyebrow">自定义计划</view>
  <view class="title">基于 AI 计划微调</view>
  <view class="muted">只能从现有动作库替换或增加动作。保存后会生成新版本，原始 AI 计划仍可恢复。</view>

  <view wx:if="{{draft}}" class="card">
    <view class="eyebrow">每周训练频次</view>
    <view class="choice-grid frequency-grid">
      <view wx:for="{{frequencyOptions}}" wx:key="*this" class="choice {{draft.frequency == item ? 'active' : ''}}" data-value="{{item}}" bindtap="setFrequency">每周 {{item}} 次</view>
    </view>
  </view>

  <view wx:if="{{draft && review}}" class="card review-card {{review.level == 'warning' ? 'warning' : ''}}">
    <view class="eyebrow">教练建议</view>
    <text class="card-title">{{review.level == 'warning' ? '先看这些风险' : '这版可以执行'}}</text>
    <view class="muted">{{review.summary}}</view>
    <view wx:if="{{reviewItems.length}}" class="review-list">
      <view wx:for="{{reviewItems}}" wx:key="text" class="review-row {{item.type}}">
        <text>{{item.label}}</text>
        <text>{{item.text}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{draft}}" class="editor-stack">
    <view wx:for="{{draft.workouts}}" wx:for-item="workout" wx:for-index="workoutIndex" wx:key="id" class="card editor-workout">
      <view class="eyebrow">训练日 {{workoutIndex + 1}}</view>
      <view class="field">
        <text class="label">训练日主题</text>
        <input class="input" value="{{workout.title}}" maxlength="18" data-workout-index="{{workoutIndex}}" data-key="title" bindinput="setWorkoutField" />
      </view>
      <view class="field">
        <text class="label">本日重点说明</text>
        <textarea class="textarea" value="{{workout.focus}}" maxlength="80" data-workout-index="{{workoutIndex}}" data-key="focus" bindinput="setWorkoutField" />
      </view>

      <view class="editor-list">
        <view wx:for="{{workout.exercises}}" wx:for-item="exercise" wx:for-index="exerciseIndex" wx:key="id" class="editor-exercise">
          <image class="thumb" src="{{exercise.image}}" mode="aspectFit" />
          <view class="editor-fields">
            <text class="item-title">{{exercise.name}}</text>
            <picker range="{{exerciseOptions}}" range-key="name" data-workout-index="{{workoutIndex}}" data-exercise-index="{{exerciseIndex}}" bindchange="replaceExercise">
              <view class="picker-button">替换动作</view>
            </picker>
            <view class="mini-grid">
              <view>
                <text class="label mini-label">组数</text>
                <input class="input mini-input" value="{{exercise.sets}}" data-workout-index="{{workoutIndex}}" data-exercise-index="{{exerciseIndex}}" data-key="sets" bindinput="setExerciseField" />
              </view>
              <view>
                <text class="label mini-label">次数 / 时长</text>
                <input class="input mini-input" value="{{exercise.reps}}" data-workout-index="{{workoutIndex}}" data-exercise-index="{{exerciseIndex}}" data-key="reps" bindinput="setExerciseField" />
              </view>
            </view>
            <text class="item-meta">{{exercise.equipmentName}}</text>
          </view>
          <button class="small-button danger-button" data-workout-index="{{workoutIndex}}" data-exercise-index="{{exerciseIndex}}" bindtap="removeExercise">删除</button>
        </view>
      </view>

      <button class="secondary-button" data-workout-index="{{workoutIndex}}" bindtap="addExercise">增加动作</button>
    </view>
  </view>

  <view wx:if="{{draft}}" class="card">
    <button class="primary-button" bindtap="savePlan">保存为当前执行计划</button>
    <button class="ghost-button" bindtap="cancel">放弃修改</button>
  </view>
</view>
