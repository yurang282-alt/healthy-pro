.frequency-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.editor-stack {
  margin-top: 24rpx;
}

.review-card {
  border-color: rgba(21, 122, 85, 0.22);
}

.review-card.warning {
  border-color: rgba(179, 107, 22, 0.32);
}

.review-card .card-title {
  margin-top: 4rpx;
}

.workout-tabs {
  position: sticky;
  top: 0;
  z-index: 5;
  display: flex;
  gap: 12rpx;
  margin: 22rpx -24rpx 0;
  padding: 16rpx 24rpx;
  overflow-x: auto;
  background: #f3f5f7;
}

.workout-tab {
  flex: 0 0 190rpx;
  padding: 16rpx;
  border: 1rpx solid #d9e0e8;
  border-radius: 14rpx;
  background: #ffffff;
}

.workout-tab text {
  display: block;
  min-width: 0;
}

.workout-tab text:first-child {
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
}

.workout-tab text:last-child {
  margin-top: 4rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.workout-tab.active {
  border-color: rgba(21, 122, 85, 0.46);
  background: #eaf4ef;
}

.workout-tab.active text:first-child,
.workout-tab.active text:last-child {
  color: #145640;
}

.review-list {
  display: grid;
  gap: 10rpx;
  margin-top: 16rpx;
}

.review-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr);
  gap: 12rpx;
  align-items: flex-start;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f6f7f8;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.42;
}

.review-row text:first-child {
  color: #157a55;
  font-weight: 900;
}

.review-row.warning {
  background: #fff7e8;
  color: #7a4b11;
}

.review-row.warning text:first-child {
  color: #b36b16;
}

.review-row.positive {
  background: #eaf4ef;
  color: #145640;
}

.editor-workout + .editor-workout {
  margin-top: 24rpx;
}

.editor-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
}

.editor-exercise {
  display: grid;
  grid-template-columns: 96rpx minmax(0, 1fr);
  gap: 16rpx;
  padding: 18rpx;
  border: 1rpx solid #d9e0e8;
  border-radius: 14rpx;
  background: #ffffff;
}

.editor-fields {
  min-width: 0;
}

.exercise-title-row {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.exercise-title-row .item-title {
  flex: 1;
  min-width: 0;
}

.move-actions {
  display: flex;
  flex: 0 0 auto;
  gap: 8rpx;
}

.move-button {
  min-height: 48rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  color: #405166;
  font-size: 22rpx;
  line-height: 48rpx;
}

.move-button[disabled] {
  color: #a8b3c1;
  background: #f6f7f8;
}

.picker-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54rpx;
  margin-top: 10rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.32);
  border-radius: 10rpx;
  color: #157a55;
  background: #eaf4ef;
  font-size: 24rpx;
  font-weight: 900;
}

.mini-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.prescription-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.mini-label {
  margin-bottom: 6rpx;
  color: #667085;
  font-size: 22rpx;
}

.mini-input {
  min-height: 68rpx;
  padding: 12rpx 14rpx;
  font-size: 26rpx;
}

.danger-button {
  grid-column: 2;
  justify-self: flex-start;
  margin-top: 8rpx;
  color: #9f2f2f;
  border-color: #f0c6c6;
  background: #fff7f7;
}

.editor-action-card {
  position: sticky;
  bottom: 20rpx;
  z-index: 6;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.14);
}

@media (max-width: 360px) {
  .prescription-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .move-actions {
    flex-direction: column;
  }
}
