.frequency-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.editor-intro {
  margin-top: 10rpx;
}

.editor-stack {
  margin-top: 24rpx;
}

.review-card {
  border-color: rgba(21, 122, 85, 0.22);
}

.review-card.warning {
  border-color: rgba(179, 107, 22, 0.32);
}

.review-card .card-title {
  margin-top: 4rpx;
}

.workout-tabs {
  position: sticky;
  top: 0;
  z-index: 5;
  display: flex;
  gap: 12rpx;
  width: 100%;
  max-width: 100%;
  margin: 18rpx 0 0;
  padding: 12rpx 0 10rpx;
  overflow-x: auto;
  background: #f3f5f7;
}

.plan-settings-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 14rpx;
  padding: 18rpx;
  border: 1rpx solid #d9e0e8;
  border-radius: 14rpx;
  background: #ffffff;
}

.plan-settings-toggle view {
  min-width: 0;
}

.plan-settings-toggle text {
  display: block;
}

.plan-settings-toggle view text:first-child {
  color: #111827;
  font-size: 27rpx;
  font-weight: 900;
}

.plan-settings-toggle view text:last-child {
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
}

.plan-settings-toggle > text {
  flex: 0 0 auto;
  color: #157a55;
  font-size: 24rpx;
  font-weight: 900;
}

.plan-settings-panel {
  display: grid;
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.18);
  border-radius: 16rpx;
  background: #fbfefd;
}

.settings-section + .settings-section {
  padding-top: 16rpx;
  border-top: 1rpx solid #e1e7ee;
}

.workout-tab {
  flex: 0 0 190rpx;
  padding: 16rpx;
  border: 1rpx solid #d9e0e8;
  border-radius: 14rpx;
  background: #ffffff;
}

.workout-tab text {
  display: block;
  min-width: 0;
}

.workout-tab text:first-child {
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
}

.workout-tab text:last-child {
  margin-top: 4rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.workout-tab.active {
  border-color: rgba(21, 122, 85, 0.46);
  background: #eaf4ef;
}

.workout-tab.active text:first-child,
.workout-tab.active text:last-child {
  color: #145640;
}

.review-list {
  display: grid;
  gap: 10rpx;
  margin-top: 16rpx;
}

.review-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr);
  gap: 12rpx;
  align-items: flex-start;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f6f7f8;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.42;
}

.review-row text:first-child {
  color: #157a55;
  font-weight: 900;
}

.review-row.warning {
  background: #fff7e8;
  color: #7a4b11;
}

.review-row.warning text:first-child {
  color: #b36b16;
}

.review-row.positive {
  background: #eaf4ef;
  color: #145640;
}

.editor-workout + .editor-workout {
  margin-top: 24rpx;
}

.editor-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
}

.editor-exercise {
  display: flex;
  width: 100%;
  min-width: 0;
  flex-direction: column;
  gap: 16rpx;
  padding: 18rpx;
  border: 1rpx solid #d9e0e8;
  border-radius: 14rpx;
  background: #ffffff;
}

.exercise-summary {
  display: flex;
  min-width: 0;
  gap: 16rpx;
  align-items: flex-start;
}

.exercise-copy {
  flex: 1;
  min-width: 0;
}

.exercise-summary .item-title,
.exercise-summary .item-meta,
.exercise-load-summary {
  display: block;
}

.exercise-summary .item-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.24;
  word-break: break-all;
}

.exercise-summary .item-meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.35;
}

.exercise-load-summary {
  margin-top: 6rpx;
  color: #176b4d;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.35;
}

.exercise-actions {
  display: flex;
  width: 100%;
  min-width: 0;
  gap: 10rpx;
  align-items: center;
}

.move-button {
  flex: 0 0 108rpx;
  width: 108rpx;
  min-height: 80rpx;
  padding: 0;
  border-radius: 10rpx;
  color: #405166;
  font-size: 24rpx;
  line-height: 80rpx;
}

.move-button[disabled] {
  color: #a8b3c1;
  background: #f6f7f8;
}

.edit-button {
  flex: 1;
  min-width: 0;
  min-height: 80rpx;
  padding: 0 16rpx;
  color: #157a55;
  border-color: rgba(21, 122, 85, 0.28);
  background: #eef8f2;
  line-height: 80rpx;
}

.exercise-editor-drawer {
  display: grid;
  gap: 14rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.18);
  border-radius: 14rpx;
  background: #f8fcfa;
}

.replace-picker {
  width: 100%;
  min-width: 0;
}

.picker-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 72rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.32);
  border-radius: 10rpx;
  color: #157a55;
  background: #eaf4ef;
  font-size: 24rpx;
  font-weight: 900;
}

.mini-grid {
  display: grid;
  gap: 12rpx;
  width: 100%;
  min-width: 0;
}

.prescription-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.mini-label {
  margin-bottom: 6rpx;
  color: #667085;
  font-size: 22rpx;
}

.mini-input {
  width: 100%;
  min-height: 80rpx;
  padding: 12rpx 14rpx;
  font-size: 26rpx;
}

.danger-button {
  width: 100%;
  min-height: 80rpx;
  line-height: 80rpx;
  color: #9f2f2f;
  border-color: #f0c6c6;
  background: #fff7f7;
}

.editor-action-card {
  position: sticky;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  z-index: 6;
  width: 100%;
  max-width: 100%;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.14);
}

.save-state {
  color: #667085;
  font-size: 23rpx;
  font-weight: 800;
  text-align: center;
}

.save-state.changed {
  color: #157a55;
}

.editor-action-card .primary-button {
  margin-top: 12rpx;
}

@media (max-width: 360px) {
  .prescription-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .move-button {
    flex-basis: 96rpx;
    width: 96rpx;
  }
}
