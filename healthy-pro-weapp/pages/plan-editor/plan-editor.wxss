.frequency-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.editor-stack {
  margin-top: 24rpx;
}

.editor-workout + .editor-workout {
  margin-top: 24rpx;
}

.editor-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
}

.editor-exercise {
  display: grid;
  grid-template-columns: 96rpx minmax(0, 1fr);
  gap: 16rpx;
  padding: 18rpx;
  border: 1rpx solid #d9e0e8;
  border-radius: 14rpx;
  background: #ffffff;
}

.editor-fields {
  min-width: 0;
}

.picker-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54rpx;
  margin-top: 10rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.32);
  border-radius: 10rpx;
  color: #157a55;
  background: #eaf4ef;
  font-size: 24rpx;
  font-weight: 900;
}

.mini-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.mini-label {
  margin-bottom: 6rpx;
  color: #667085;
  font-size: 22rpx;
}

.mini-input {
  min-height: 68rpx;
  padding: 12rpx 14rpx;
  font-size: 26rpx;
}

.danger-button {
  grid-column: 2;
  justify-self: flex-start;
  margin-top: 8rpx;
  color: #9f2f2f;
  border-color: #f0c6c6;
  background: #fff7f7;
}
