.back-button {
  margin-bottom: 18rpx;
}

.hero-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.detail-image {
  width: 100%;
  height: 320rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 16rpx;
  background: #f6f7f8;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.detail-grid .light-metric {
  min-width: 0;
  padding: 16rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
}

.detail-grid .metric-value {
  color: #111827;
  font-size: 27rpx;
}

.safety-note {
  padding: 16rpx;
  border-radius: 14rpx;
  background: #fff7ed;
  color: #8a4b0b;
  font-size: 25rpx;
  line-height: 1.45;
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 16rpx;
}

.guide-item {
  color: #111827;
  font-size: 27rpx;
  line-height: 1.45;
}

.load-detail {
  margin-top: 10rpx;
}

.warning-card {
  border-color: #f1d2b5;
  background: #fffaf3;
}

.related-row {
  align-items: center;
}
