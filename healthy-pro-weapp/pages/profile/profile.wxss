.profile-button {
  width: 72%;
  margin-left: auto;
  margin-right: auto;
}

.profile-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.profile-actions .secondary-button,
.profile-actions .ghost-button {
  min-height: 66rpx;
  margin-top: 0;
  font-size: 25rpx;
  line-height: 66rpx;
}

.progress-track,
.trend-track {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #edf1f5;
}

.progress-track {
  margin-top: 18rpx;
}

.progress-fill,
.trend-fill {
  display: block;
  height: 100%;
  border-radius: 999rpx;
  background: #157a55;
}

.trend-fill.soft {
  background: rgba(21, 122, 85, 0.42);
}

.coach-message {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: #fff7ed;
  color: #8a4b0b;
  font-size: 25rpx;
  line-height: 1.45;
}

.trend-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.trend-row {
  display: grid;
  grid-template-columns: 128rpx 1fr;
  gap: 12rpx;
  align-items: center;
}

.trend-meta {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.trend-meta text:first-child {
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
}

.trend-meta text:last-child {
  color: #667085;
  font-size: 22rpx;
}

.record-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.record-cell,
.friend-summary view {
  min-width: 0;
  padding: 16rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #f6f7f8;
}

.record-cell text,
.friend-summary text {
  display: block;
}

.record-cell text:first-child,
.friend-summary text:first-child {
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
}

.record-value,
.friend-summary text:last-child {
  margin-top: 6rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.record-note {
  margin-top: 4rpx;
  color: #667085;
  font-size: 21rpx;
  line-height: 1.35;
}

.friend-summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.feedback-textarea {
  min-height: 150rpx;
  margin-top: 16rpx;
}
