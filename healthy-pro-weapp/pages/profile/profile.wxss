.profile-button {
  width: 72%;
  margin-left: auto;
  margin-right: auto;
}

.profile-identity .card-title {
  margin-top: 4rpx;
}

.profile-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.profile-chip-row text {
  min-height: 48rpx;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  color: #18385e;
  background: rgba(40, 79, 130, 0.09);
  font-size: 23rpx;
  font-weight: 900;
  line-height: 30rpx;
}

.profile-summary-card {
  border-color: rgba(21, 122, 85, 0.22);
}

.weekly-plan-line {
  margin-top: 8rpx;
}

.weekly-inline-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 18rpx;
  margin-top: 14rpx;
  color: #405166;
  font-size: 23rpx;
  font-weight: 800;
}

.profile-hub .card-title {
  margin-top: 4rpx;
}

.profile-entry-list {
  display: grid;
  gap: 10rpx;
  margin-top: 12rpx;
}

.profile-entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 92rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
}

.profile-menu-title {
  display: block;
  margin-top: 28rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.profile-entry-card text {
  display: block;
}

.entry-eyebrow {
  color: #157a55;
  font-size: 22rpx;
  font-weight: 900;
}

.entry-title {
  margin-top: 5rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.entry-arrow {
  flex: 0 0 auto;
  color: #98a2b3;
  font-size: 40rpx;
  font-weight: 500;
  line-height: 1;
}

.entry-summary {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
}

.profile-entry-card:active {
  border-color: rgba(21, 122, 85, 0.46);
  background: #f2faf6;
}

.profile-subhead {
  display: grid;
  gap: 14rpx;
  margin-bottom: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 16rpx;
  background: #ffffff;
}

.profile-subhead .small-button {
  width: 132rpx;
  min-height: 72rpx;
  line-height: 72rpx;
}

.profile-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.profile-actions .secondary-button,
.profile-actions .ghost-button {
  min-height: 80rpx;
  margin-top: 0;
  font-size: 25rpx;
  line-height: 80rpx;
}

.progress-track,
.trend-track {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #edf1f5;
}

.progress-track {
  margin-top: 18rpx;
}

.progress-fill,
.trend-fill {
  display: block;
  height: 100%;
  border-radius: 999rpx;
  background: #157a55;
}

.trend-fill.soft {
  background: rgba(21, 122, 85, 0.42);
}

.trend-fill.warm {
  background: rgba(179, 107, 22, 0.52);
}

.coach-message {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: #fff7ed;
  color: #8a4b0b;
  font-size: 25rpx;
  line-height: 1.45;
}

.trend-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.trend-row {
  display: grid;
  grid-template-columns: 128rpx 1fr;
  gap: 12rpx;
  align-items: center;
}

.trend-meta {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.trend-meta text:first-child {
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
}

.trend-meta text:last-child {
  color: #667085;
  font-size: 22rpx;
}

.record-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.body-trend-list {
  display: grid;
  gap: 10rpx;
  margin-top: 16rpx;
}

.body-trend-row {
  display: grid;
  grid-template-columns: minmax(0, 1.4fr) minmax(0, 0.8fr) minmax(0, 0.8fr);
  gap: 10rpx;
  padding: 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #f8fafb;
}

.body-trend-row text {
  color: #667085;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.35;
}

.body-trend-row text:nth-child(2) {
  color: #111827;
  font-weight: 900;
}

.record-cell,
.friend-summary view {
  min-width: 0;
  padding: 16rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #f6f7f8;
}

.record-cell text,
.friend-summary text {
  display: block;
}

.record-cell text:first-child,
.friend-summary text:first-child {
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
}

.record-value,
.friend-summary text:last-child {
  margin-top: 6rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.record-note {
  margin-top: 4rpx;
  color: #667085;
  font-size: 21rpx;
  line-height: 1.35;
}

.friend-summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.friend-activity {
  margin-top: 22rpx;
}

.friend-activity-head,
.activity-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.friend-activity-head {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.friend-activity-head text:last-child {
  color: #667085;
  font-size: 22rpx;
}

.activity-list {
  display: grid;
  gap: 12rpx;
  margin-top: 12rpx;
}

.activity-row {
  padding: 16rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
}

.activity-row text {
  display: block;
}

.activity-row view text:first-child {
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
}

.activity-row view text:last-child {
  margin-top: 5rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.4;
}

.activity-row > text {
  flex: 0 0 auto;
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

.feedback-textarea {
  min-height: 150rpx;
  margin-top: 16rpx;
}

.form-block {
  margin-top: 18rpx;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
}

.text-input {
  width: 100%;
  min-height: 72rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
  color: #111827;
  font-size: 27rpx;
  font-weight: 800;
}

.friend-code-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f2faf6;
  border: 1rpx solid rgba(21, 122, 85, 0.18);
}

.friend-code-card text {
  display: block;
}

.friend-code-card text:first-child {
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
}

.friend-code {
  margin-top: 4rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.share-grid,
.choice-grid {
  display: grid;
  gap: 12rpx;
  margin-top: 14rpx;
}

.share-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.check-card,
.choice-card {
  min-width: 0;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
  color: #667085;
  font-weight: 900;
}

.check-card {
  padding: 16rpx;
}

.check-card text {
  display: block;
}

.check-card text:first-child {
  color: #111827;
  font-size: 25rpx;
}

.check-card text:last-child {
  margin-top: 4rpx;
  color: #667085;
  font-size: 21rpx;
  line-height: 1.35;
}

.check-card.selected,
.choice-card.selected {
  border-color: rgba(21, 122, 85, 0.46);
  background: #eaf4ef;
  color: #157a55;
}

.add-friend-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 12rpx;
  align-items: center;
  margin-top: 18rpx;
}

.leaderboard,
.friend-list,
.release-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 18rpx;
}

.leaderboard-row,
.friend-card,
.release-card {
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
}

.leaderboard-row {
  display: grid;
  grid-template-columns: 50rpx 1fr;
  gap: 12rpx;
  align-items: center;
  padding: 14rpx;
}

.leaderboard-row.self {
  background: #f2faf6;
  border-color: rgba(21, 122, 85, 0.22);
}

.leaderboard-row > text {
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
}

.leaderboard-row view text,
.friend-card view text {
  display: block;
}

.leaderboard-row view text:first-child,
.friend-card view text:first-child {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.leaderboard-row view text:last-child,
.friend-card view text:last-child {
  margin-top: 3rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.38;
}

.friend-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 14rpx;
}

.friend-actions {
  display: flex;
  gap: 8rpx;
}

.small-button.subtle {
  color: #667085;
  background: #ffffff;
}

.muted-pill {
  color: #667085;
  background: #f6f7f8;
}

.empty-inline {
  margin-top: 12rpx;
  font-size: 23rpx;
}

.release-card {
  padding: 16rpx;
}

.release-card.unread {
  border-color: rgba(21, 122, 85, 0.26);
  background: #fbfefd;
}

.release-head {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.release-head text {
  display: block;
}

.release-head view text:first-child,
.release-head > text {
  color: #667085;
  font-size: 21rpx;
  font-weight: 800;
}

.release-head view text:last-child {
  margin-top: 4rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.release-highlights {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-top: 10rpx;
  color: #176b4d;
  font-size: 23rpx;
  line-height: 1.4;
}

.read-mark {
  display: block;
  margin-top: 12rpx;
  color: #667085;
  font-size: 23rpx;
  font-weight: 800;
}

.compact-button {
  min-height: 58rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 58rpx;
}

.rating-grid {
  grid-template-columns: repeat(5, minmax(0, 1fr));
}

.category-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.choice-card {
  min-height: 62rpx;
  padding: 10rpx 8rpx;
  text-align: center;
  font-size: 23rpx;
}

.choice-card text {
  display: block;
}

.choice-card text:first-child {
  color: #111827;
  font-size: 23rpx;
}

.choice-card text:last-child {
  margin-top: 2rpx;
  color: #667085;
  font-size: 18rpx;
  font-weight: 800;
}
