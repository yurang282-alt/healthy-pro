<view class="page">
  <view class="cockpit-header">
    <view>
      <view class="eyebrow">Healthy Pro</view>
      <view class="title">训练驾驶舱</view>
    </view>
  </view>

  <view wx:if="{{workout}}" class="dark-card home-hero cockpit-hero">
    <view class="cockpit-status-row">
      <view>
        <view class="eyebrow">今日指令</view>
        <text class="card-title">{{workout.title}}</text>
      </view>
      <text class="stage-pill">{{cockpit.stageLabel}}</text>
    </view>
    <view class="hero-focus">{{workout.focus}}</view>

    <view class="cockpit-metric-grid">
      <view class="cockpit-metric">
        <text>预计</text>
        <text class="metric-value">{{cockpit.durationLabel}}</text>
      </view>
      <view class="cockpit-metric">
        <text>动作</text>
        <text class="metric-value">{{cockpit.exercisesLabel}}</text>
      </view>
      <view class="cockpit-metric">
        <text>进度</text>
        <text class="metric-value">{{cockpit.progressLabel}}</text>
      </view>
    </view>

    <view class="readiness-strip">
      <view>
        <text>{{cockpit.readinessTitle}}</text>
        <text>{{cockpit.readinessText}}</text>
      </view>
    </view>

    <button class="primary-button cockpit-primary-action" bindtap="startTraining">{{cockpit.primaryAction}}</button>
    <view class="cockpit-secondary-link" bindtap="goPlan">查看完整计划</view>
  </view>

  <view wx:if="{{firstUseGuide.visible}}" class="card onboarding-card">
    <view class="row">
      <view>
        <view class="eyebrow">{{firstUseGuide.eyebrow}}</view>
        <text class="card-title">{{firstUseGuide.title}}</text>
      </view>
      <button class="small-button subtle" bindtap="dismissFirstUseGuide">{{firstUseGuide.dismissText}}</button>
    </view>
    <view class="muted guide-summary">{{firstUseGuide.summary}}</view>
    <view class="onboarding-steps">
      <view wx:for="{{firstUseGuide.steps}}" wx:key="index" class="guide-step {{item.state}}">
        <text>{{item.index}}</text>
        <view>
          <text>{{item.title}}</text>
          <text>{{item.desc}}</text>
        </view>
      </view>
    </view>
    <button class="secondary-button guide-button" bindtap="handleGuidePrimary">{{firstUseGuide.primaryText}}</button>
  </view>

  <view wx:if="{{workout}}" class="card cockpit-card">
    <view class="section-head">
      <view>
        <view class="eyebrow">训练顺序</view>
        <text class="card-title">先完成前 3 项</text>
      </view>
      <text class="plan-chip">{{cockpit.durationLabel}}</text>
    </view>
    <view class="cockpit-list">
      <view wx:for="{{previewExercises}}" wx:for-index="exerciseIndex" wx:key="id" class="cockpit-exercise">
        <view class="exercise-index">0{{exerciseIndex + 1}}</view>
        <image class="thumb" src="{{item.image}}" mode="aspectFit" />
        <view class="item-body">
          <text class="item-title">{{item.name}}</text>
          <text class="item-meta">{{item.equipmentName}} · {{item.sets}} · {{item.reps}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{remainingCount}}" class="empty-note">后面还有 {{remainingCount}} 个动作，开始训练后继续按顺序做。</view>
  </view>

  <view wx:if="{{!plan && !firstUseGuide.visible}}" class="card">
    <text class="card-title">先完成基础评估</text>
    <view class="muted">填身高、体重、体脂和目标后，系统会生成第一版训练计划。</view>
    <button class="primary-button" bindtap="goAssessment">开始评估</button>
  </view>
</view>
