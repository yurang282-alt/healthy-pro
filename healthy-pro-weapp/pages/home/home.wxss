.cockpit-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.sync-chip,
.plan-chip,
.stage-pill {
  flex: 0 0 auto;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.sync-chip {
  margin-top: 8rpx;
  padding: 10rpx 16rpx;
  color: #175d43;
  background: #e7f3ec;
}

.stage-pill {
  padding: 10rpx 16rpx;
  color: #d7f7e5;
  border: 1rpx solid rgba(215, 247, 229, 0.22);
  background: rgba(215, 247, 229, 0.1);
}

.plan-chip {
  padding: 9rpx 15rpx;
  color: #175d43;
  background: #eef8f2;
}

.home-hero .card-title {
  font-size: 40rpx;
}

.cockpit-hero {
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  background:
    linear-gradient(145deg, rgba(26, 87, 62, 0.72), transparent 52%),
    linear-gradient(320deg, rgba(104, 72, 32, 0.4), transparent 48%),
    #101820;
  box-shadow: 0 30rpx 70rpx rgba(17, 24, 39, 0.22);
}

.cockpit-status-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.hero-focus {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  line-height: 1.48;
}

.cockpit-metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 24rpx;
}

.cockpit-metric {
  min-width: 0;
  padding: 16rpx 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
}

.cockpit-metric text {
  display: block;
  color: rgba(255, 255, 255, 0.66);
  font-size: 22rpx;
}

.cockpit-metric .metric-value {
  color: #ffffff;
}

.readiness-strip {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(215, 247, 229, 0.18);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.08);
}

.readiness-strip text {
  display: block;
}

.readiness-strip text:first-child {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.readiness-strip text:last-child {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  line-height: 1.45;
}

.dark-actions {
  align-items: stretch;
}

.dark-actions .primary-button {
  flex: 1.25;
}

.cockpit-actions .primary-button {
  color: #101820;
  background: #d7f7e5;
}

.dark-actions .ghost-button {
  color: rgba(255, 255, 255, 0.86);
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.08);
}

.onboarding-card {
  border-color: rgba(21, 122, 85, 0.22);
  background: #fbfefd;
}

.guide-summary {
  margin-top: 12rpx;
}

.onboarding-steps {
  display: grid;
  gap: 10rpx;
  margin-top: 18rpx;
}

.guide-step {
  display: grid;
  grid-template-columns: 48rpx 1fr;
  align-items: start;
  gap: 14rpx;
  min-width: 0;
  padding: 16rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
}

.guide-step text {
  display: block;
}

.guide-step > text {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  color: #667085;
  background: #eef2f5;
  font-size: 22rpx;
  font-weight: 900;
}

.guide-step view text:first-child {
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
}

.guide-step view text:last-child {
  margin-top: 6rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.4;
}

.guide-step.active {
  border-color: rgba(21, 122, 85, 0.4);
  background: #eef8f2;
}

.guide-step.active > text {
  color: #ffffff;
  background: #157a55;
}

.guide-step.done > text {
  color: #157a55;
  background: #dff1e8;
}

.guide-button {
  margin-top: 18rpx;
}

.coach-feedback-card {
  border-color: rgba(21, 122, 85, 0.25);
  background: #eef8f2;
}

.coach-feedback-card .card-title {
  margin-top: 4rpx;
}

.cockpit-card {
  border-color: rgba(17, 24, 39, 0.08);
  box-shadow: 0 18rpx 46rpx rgba(17, 24, 39, 0.05);
}

.cockpit-list {
  display: grid;
  gap: 14rpx;
  margin-top: 16rpx;
}

.cockpit-exercise {
  display: grid;
  grid-template-columns: 52rpx 96rpx 1fr;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 16rpx;
  background: #fbfcfd;
}

.exercise-index {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  color: #175d43;
  background: #e7f3ec;
  font-size: 20rpx;
  font-weight: 900;
}

.home-status-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.home-status-tags text {
  min-height: 40rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #eef3f6;
  color: #344052;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 28rpx;
}

.progress-card {
  background: #fbfcfd;
}

.progress-track {
  overflow: hidden;
  height: 12rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: #e6ebf0;
}

.progress-track view {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #1b7a58, #52b788);
}

.coach-note {
  display: grid;
  gap: 8rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border-left: 6rpx solid #1b7a58;
  border-radius: 14rpx;
  background: #eef8f2;
}

.coach-note text {
  display: block;
  color: #45515f;
  font-size: 24rpx;
  line-height: 1.42;
}

.coach-note text:first-child {
  color: #175d43;
  font-size: 22rpx;
  font-weight: 900;
}

.coach-note text:nth-child(2) {
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.compact-coach-note {
  grid-template-columns: auto 1fr;
  align-items: center;
}

.compact-coach-note text:nth-child(2) {
  margin-top: 0;
}
