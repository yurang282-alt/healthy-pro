.thumb {
  width: 112rpx;
  height: 112rpx;
}

.equipment-group-stack {
  display: grid;
  gap: 28rpx;
  margin-top: 28rpx;
}

.equipment-section {
  min-width: 0;
}

.equipment-section .card-title {
  margin-top: 4rpx;
}

.equipment-library-head {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.equipment-category {
  display: block;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e1e7ee;
  color: #157a55;
  font-size: 25rpx;
  font-weight: 900;
}

.compact-list {
  margin-top: 16rpx;
  gap: 12rpx;
}

.equipment-row {
  align-items: center;
}

.equipment-library-toggle {
  width: 100%;
  min-height: 80rpx;
  margin-top: 20rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.24);
  border-radius: 14rpx;
  color: #157a55;
  background: #f2faf6;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 80rpx;
}
