<view class="page">
  <view class="eyebrow">Healthy Pro</view>
  <view class="title">计划控制台</view>

  <view wx:if="{{plan}}" class="dark-card plan-console-card">
    <view class="plan-command-head">
      <view>
        <view class="eyebrow">本周阶段</view>
        <text class="card-title">{{planConsole.stageLabel}}</text>
        <text class="plan-command-focus">{{planConsole.nextWorkoutFocus}}</text>
      </view>
      <text class="phase-tag dark">{{versionLabel}}</text>
    </view>

    <view class="plan-next-block">
      <text>下一次训练</text>
      <text>{{planConsole.nextWorkoutTitle}}</text>
    </view>

    <view class="plan-console-metrics">
      <view>
        <text>频次</text>
        <text>{{planConsole.frequencyLabel}}</text>
      </view>
      <view>
        <text>单次时长</text>
        <text>{{planConsole.durationLabel}}</text>
      </view>
      <view>
        <text>重点</text>
        <text>{{planConsole.focusLabel}}</text>
      </view>
    </view>

    <view class="plan-command-progress">
      <view style="width: {{planConsole.progressPercent}}%;"></view>
    </view>

    <button class="primary-button plan-start-button" bindtap="goLog">开始训练</button>
    <view class="plan-edit-link" bindtap="editPlan">编辑当前计划</view>
  </view>

  <view wx:if="{{plan}}" class="card plan-overview-card">
    <view class="section-head">
      <view>
        <view class="eyebrow">周期选择</view>
        <text class="card-title">4 周训练节奏</text>
      </view>
      <text class="plan-chip">{{selectedWeekInfo.label}}</text>
    </view>

    <view class="week-grid">
      <view wx:for="{{plan.weeks}}" wx:key="week" class="week-chip {{selectedWeek == item.week ? 'active' : ''}}" data-week="{{item.week}}" bindtap="chooseWeek">
        <text>第 {{item.week}} 周{{currentWeek == item.week ? ' · 当前' : ''}}</text>
        <text class="week-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{plan}}" class="card plan-timeline-card">
    <view class="section-head">
      <view>
        <view class="eyebrow">动作安排</view>
        <text class="card-title">这一周怎么练</text>
      </view>
      <text class="plan-chip">{{planConsole.frequencyLabel}}</text>
    </view>
    <view class="list workout-stack">
      <view wx:for="{{plan.workouts}}" wx:for-index="workoutIndex" wx:key="id" class="workout-card {{expandedWorkoutId == item.id ? 'active' : ''}}">
        <view class="row workout-head" data-id="{{item.id}}" bindtap="toggleWorkout">
          <view class="workout-day-index">{{workoutIndex + 1}}</view>
          <view>
            <text class="card-title workout-title">{{item.title}}</text>
            <view class="muted">{{item.focus}}</view>
          </view>
          <text class="pill">{{expandedWorkoutId == item.id ? plan.duration.label : item.exercises.length + ' 个动作'}}</text>
        </view>
        <view wx:if="{{expandedWorkoutId == item.id}}" class="list">
          <view wx:for="{{item.exercises}}" wx:for-item="exercise" wx:key="id" class="exercise-row">
            <image class="thumb" src="{{exercise.image}}" mode="aspectFit" />
            <view class="item-body">
              <text class="item-title">{{exercise.name}}</text>
              <text class="item-meta">{{exercise.equipmentName}} · {{exercise.sets}} · {{exercise.reps}}</text>
              <view class="exercise-status-row">
                <text wx:if="{{exercise.load}}">起步 {{exercise.load}}</text>
                <text>吃力 {{exercise.effort}}</text>
              </view>
              <button class="small-button detail-button" data-id="{{exercise.sourceExerciseId || exercise.id}}" bindtap="viewExercise">看动作详情</button>
            </view>
          </view>
        </view>
        <view wx:else class="workout-summary" data-id="{{item.id}}" bindtap="toggleWorkout">点击展开动作和建议重量</view>
      </view>
    </view>
  </view>

  <view wx:if="{{plan}}" class="plan-drawer-toggle" bindtap="togglePlanTools">
    <view>
      <view class="eyebrow">计划设置</view>
      <text>调整、评估与版本恢复</text>
    </view>
    <text>{{showPlanTools ? '收起' : '展开'}}</text>
  </view>

  <view wx:if="{{plan && showPlanTools}}" class="plan-tools-strip">
    <view class="row">
      <view>
        <view class="eyebrow">计划设置</view>
        <text class="card-title">调整与恢复</text>
      </view>
      <text class="pill">{{versionLabel}}</text>
    </view>
    <view class="plan-management-actions">
      <button class="secondary-button" bindtap="adjustPlan">按记录调整</button>
      <button class="ghost-button" bindtap="goAssessment">重新评估</button>
    </view>
    <view class="action-row secondary-plan-actions">
      <button wx:if="{{canRestoreOriginal}}" class="ghost-button" bindtap="restoreOriginal">恢复 AI</button>
      <button wx:if="{{previousPlan}}" class="secondary-button" bindtap="restorePrevious">恢复上一版</button>
      <button wx:if="{{previousPlan}}" class="ghost-button" bindtap="togglePreviousPlan">{{showPreviousPlan ? '收起旧版' : '查看旧版'}}</button>
    </view>
  </view>

  <view wx:if="{{showPreviousPlan && previousPlan}}" class="card previous-plan-card">
    <view class="row">
      <view>
        <view class="eyebrow">上一版计划</view>
        <text class="card-title">{{previousPlan.customization.label || '历史版本'}}</text>
      </view>
      <text class="pill">{{previousPlan.frequency.sessionsPerWeek}} 次/周</text>
    </view>
    <view class="previous-list">
      <view wx:for="{{previousPlan.workouts}}" wx:key="id" class="history-row">
        <view class="item-body">
          <text class="item-title">{{item.title}}</text>
          <text class="item-meta">{{item.focus}}</text>
          <text class="item-help">{{item.exercises.length}} 个动作</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{plan}}" class="plan-drawer-toggle coach-toggle" bindtap="toggleCoachDetails">
    <view>
      <view class="eyebrow">教练说明</view>
      <text>{{plan.goal.type}}</text>
    </view>
    <text>{{showCoachDetails ? '收起' : '查看原因'}}</text>
  </view>

  <view wx:if="{{plan && showCoachDetails}}" class="card coach-details-card">
    <view class="eyebrow">为什么这样安排</view>
    <text class="card-title">{{plan.goal.type}}</text>
    <view class="coach-note">{{plan.rationale}}</view>
    <view wx:if="{{coachDecisionSummary}}" class="adjust-explainer">{{coachDecisionSummary}}</view>
    <view wx:if="{{coachReview}}" class="plan-review {{coachReview.level == 'warning' ? 'warning' : ''}}">
      <text>{{coachReview.level == 'warning' ? '自定义计划风险' : '自定义计划审核'}}</text>
      <view>{{coachReview.summary}}</view>
      <view wx:if="{{coachReviewItems.length}}" class="review-list">
        <view wx:for="{{coachReviewItems}}" wx:key="text" class="review-row {{item.type}}">
          <text>{{item.label}}</text>
          <text>{{item.text}}</text>
        </view>
      </view>
    </view>
    <view class="fact-list">
      <view wx:for="{{coachFacts}}" wx:key="label">
        <text>{{item.label}}</text>
        <text>{{item.value}}</text>
      </view>
    </view>
    <view class="empty-note coach-guide">{{plan.adjustmentGuide}}</view>
  </view>

  <view wx:else class="card">
    <text class="card-title">还没有训练计划</text>
    <view class="muted">先完成基础评估。</view>
    <button class="primary-button" bindtap="goAssessment">开始评估</button>
  </view>
</view>
