<view class="page">
  <view class="eyebrow">Healthy Pro</view>
  <view class="title">训练计划</view>

  <view wx:if="{{plan}}" class="card plan-overview-card">
    <view class="plan-week-heading">
      <view>
        <view class="eyebrow">本周安排</view>
        <view class="week-title-line">
          <text class="card-title plan-week-title">第 {{selectedWeek}} 周</text>
          <text class="phase-tag">{{selectedWeekInfo.label}}</text>
        </view>
      </view>
    </view>

    <view class="plan-brief-grid">
      <view>
        <text>训练结构</text>
        <text class="brief-value">{{plan.frequency.pattern}}</text>
      </view>
      <view>
        <text>频次</text>
        <text class="brief-value">{{plan.frequency.sessionsPerWeek}} 次/周</text>
      </view>
      <view>
        <text>单次上限</text>
        <text class="brief-value">{{plan.duration.budget || 60}} 分钟</text>
      </view>
    </view>

    <view class="week-grid">
      <view wx:for="{{plan.weeks}}" wx:key="week" class="week-chip {{selectedWeek == item.week ? 'active' : ''}}" data-week="{{item.week}}" bindtap="chooseWeek">
        <text>第 {{item.week}} 周{{currentWeek == item.week ? ' · 当前' : ''}}</text>
        <text class="week-label">{{item.label}}</text>
      </view>
    </view>

    <view class="adjust-explainer">{{selectedWeekInfo.note}}</view>

    <view class="plan-overview-actions">
      <button class="secondary-button" bindtap="adjustPlan">重新调整</button>
      <button class="ghost-button" bindtap="goAssessment">重新评估</button>
    </view>
  </view>

  <view wx:if="{{plan}}" class="card plan-management-card">
    <view class="row">
      <view>
        <view class="eyebrow">计划管理</view>
        <text class="card-title">编辑、恢复或查看旧版</text>
      </view>
      <text class="pill">{{versionLabel}}</text>
    </view>
    <view class="plan-management-actions">
      <button class="primary-button" bindtap="editPlan">编辑计划</button>
      <button wx:if="{{canRestoreOriginal}}" class="ghost-button" bindtap="restoreOriginal">恢复 AI</button>
    </view>
    <view class="action-row secondary-plan-actions">
      <button wx:if="{{previousPlan}}" class="secondary-button" bindtap="restorePrevious">恢复上一版</button>
      <button wx:if="{{previousPlan}}" class="ghost-button" bindtap="togglePreviousPlan">{{showPreviousPlan ? '收起旧版' : '查看旧版'}}</button>
    </view>
  </view>

  <view wx:if="{{showPreviousPlan && previousPlan}}" class="card previous-plan-card">
    <view class="row">
      <view>
        <view class="eyebrow">上一版计划</view>
        <text class="card-title">{{previousPlan.customization.label || '历史版本'}}</text>
      </view>
      <text class="pill">{{previousPlan.frequency.sessionsPerWeek}} 次/周</text>
    </view>
    <view class="previous-list">
      <view wx:for="{{previousPlan.workouts}}" wx:key="id" class="history-row">
        <view class="item-body">
          <text class="item-title">{{item.title}}</text>
          <text class="item-meta">{{item.focus}}</text>
          <text class="item-help">{{item.exercises.length}} 个动作</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{plan}}" class="card">
    <view class="eyebrow">动作安排</view>
    <text class="card-title">这一周怎么练</text>
    <view class="list workout-stack">
      <view wx:for="{{plan.workouts}}" wx:key="id" class="workout-card">
        <view class="row workout-head" data-id="{{item.id}}" bindtap="toggleWorkout">
          <view>
            <text class="card-title workout-title">{{item.title}}</text>
            <view class="muted">{{item.focus}}</view>
          </view>
          <text class="pill">{{expandedWorkoutId == item.id ? plan.duration.label : item.exercises.length + ' 个动作'}}</text>
        </view>
        <view wx:if="{{expandedWorkoutId == item.id}}" class="list">
          <view wx:for="{{item.exercises}}" wx:for-item="exercise" wx:key="id" class="exercise-row">
            <image class="thumb" src="{{exercise.image}}" mode="aspectFit" />
            <view class="item-body">
              <text class="item-title">{{exercise.name}}</text>
              <text class="item-meta">{{exercise.equipmentName}} · {{exercise.sets}} · {{exercise.reps}}</text>
              <text wx:if="{{exercise.load}}" class="item-meta">建议起步：{{exercise.load}}</text>
              <text class="item-help">吃力程度 {{exercise.effort}}：{{exercise.cue}}</text>
            </view>
          </view>
        </view>
        <view wx:else class="workout-summary" data-id="{{item.id}}" bindtap="toggleWorkout">点击展开动作和建议重量</view>
      </view>
    </view>
  </view>

  <view wx:else class="card">
    <text class="card-title">还没有训练计划</text>
    <view class="muted">先完成基础评估。</view>
    <button class="primary-button" bindtap="goAssessment">开始评估</button>
  </view>
</view>
