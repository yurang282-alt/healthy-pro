.plan-console-card {
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background:
    linear-gradient(145deg, rgba(24, 106, 75, 0.72), rgba(17, 24, 39, 0) 52%),
    linear-gradient(315deg, rgba(95, 66, 32, 0.34), rgba(17, 24, 39, 0) 46%),
    #101820;
  box-shadow: 0 30rpx 70rpx rgba(17, 24, 39, 0.22);
}

.plan-command-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.plan-command-focus {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
  line-height: 1.45;
}

.phase-tag.dark {
  flex: 0 0 auto;
  color: #d7f7e5;
  border: 1rpx solid rgba(215, 247, 229, 0.22);
  background: rgba(215, 247, 229, 0.1);
}

.plan-next-block {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.09);
}

.plan-next-copy {
  min-width: 0;
  flex: 1;
}

.plan-next-copy text {
  display: block;
}

.plan-next-copy text:first-child {
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
  font-weight: 900;
}

.plan-next-copy text:last-child {
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 950;
  line-height: 1.15;
}

.plan-next-change {
  flex: 0 0 auto;
  min-width: 112rpx;
  min-height: 72rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 1rpx solid rgba(215, 247, 229, 0.28);
  border-radius: 14rpx;
  color: #d7f7e5;
  background: rgba(215, 247, 229, 0.1);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 72rpx;
}

.plan-override-note {
  margin-top: 10rpx;
  color: #d7f7e5;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.45;
}

.plan-console-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.plan-console-metrics view {
  min-width: 0;
  min-height: 100rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
}

.plan-console-metrics text {
  display: block;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.35;
}

.plan-console-metrics text:last-child {
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 950;
}

.plan-command-progress {
  overflow: hidden;
  height: 10rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
}

.plan-command-progress view {
  height: 100%;
  border-radius: inherit;
  background: #d7f7e5;
}

.plan-console-card .plan-start-button {
  color: #101820;
  border-color: transparent;
  background: #d7f7e5;
}

.plan-edit-link {
  min-height: 72rpx;
  padding-top: 20rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  font-weight: 900;
  text-align: center;
}

.plan-overview-card {
  padding-bottom: 22rpx;
}

.week-title-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 4rpx;
}

.plan-week-title {
  font-size: 42rpx;
}

.phase-tag {
  min-height: 44rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #eaf4ef;
  color: #157a55;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 30rpx;
}

.plan-brief-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.plan-brief-grid view {
  min-height: 102rpx;
  padding: 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #f8fafb;
}

.plan-brief-grid text {
  display: block;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.35;
}

.plan-brief-grid .brief-value {
  margin-top: 8rpx;
  color: #111827;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.28;
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.week-chip {
  min-height: 86rpx;
  padding: 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
}

.week-chip text {
  display: block;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.35;
}

.week-label {
  margin-top: 4rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.week-chip.active {
  border-color: rgba(21, 122, 85, 0.5);
  background: #eaf4ef;
}

.adjust-explainer {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #fff7e8;
  color: #7a4b11;
  font-size: 24rpx;
  line-height: 1.45;
}

.plan-management-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.plan-tools-strip {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.08);
  border-radius: 18rpx;
  background: #fbfcfd;
}

.plan-drawer-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.08);
  border-radius: 18rpx;
  background: #fbfcfd;
}

.plan-drawer-toggle view {
  min-width: 0;
}

.plan-drawer-toggle view > text {
  display: block;
  margin-top: 4rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.plan-drawer-toggle > text {
  flex: 0 0 auto;
  min-height: 48rpx;
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  color: #175d43;
  background: #eaf4ef;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.coach-toggle {
  border-color: rgba(21, 122, 85, 0.14);
}

.plan-overview-actions .secondary-button,
.plan-overview-actions .ghost-button,
.plan-management-actions .secondary-button,
.plan-management-actions .ghost-button,
.secondary-plan-actions .secondary-button,
.secondary-plan-actions .ghost-button {
  min-height: 80rpx;
  margin-top: 0;
  font-size: 25rpx;
  line-height: 80rpx;
}

.secondary-plan-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.plan-tools-strip .pill {
  max-width: 190rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-tools-strip .card-title {
  font-size: 32rpx;
}

.previous-list {
  margin-top: 16rpx;
}

.previous-list .history-row + .history-row {
  margin-top: 12rpx;
}

.plan-timeline-card {
  border-color: rgba(17, 24, 39, 0.08);
}

.workout-stack {
  gap: 16rpx;
}

.workout-card {
  position: relative;
  padding: 16rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 16rpx;
  background: #fbfcfd;
}

.workout-card.active {
  border-color: rgba(21, 122, 85, 0.36);
  background: #f3faf6;
}

.workout-head {
  align-items: center;
  justify-content: flex-start;
}

.workout-head .pill {
  margin-left: auto;
}

.workout-day-index {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  color: #175d43;
  background: #e7f3ec;
  font-size: 24rpx;
  font-weight: 950;
}

.workout-title {
  font-size: 32rpx;
}

.workout-summary {
  margin-top: 10rpx;
  padding-left: 70rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.4;
}

.exercise-status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.exercise-status-row text {
  min-height: 42rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #eef3f6;
  color: #344052;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 28rpx;
}

.coach-details-card {
  border-color: rgba(21, 122, 85, 0.18);
}

.coach-note {
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.55;
}

.plan-review {
  margin-top: 16rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.2);
  border-radius: 14rpx;
  background: #f2faf6;
}

.plan-review.warning {
  border-color: rgba(179, 107, 22, 0.28);
  background: #fff7e8;
}

.plan-review > text {
  display: block;
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.plan-review > view {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.review-list {
  display: grid;
  gap: 10rpx;
  margin-top: 12rpx;
}

.review-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr);
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #ffffff;
}

.review-row text:first-child {
  color: #157a55;
  font-weight: 900;
}

.review-row.warning text:first-child {
  color: #b36b16;
}

.review-row text:last-child {
  color: #667085;
  font-size: 23rpx;
  line-height: 1.42;
}

.fact-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.fact-list view {
  min-width: 0;
  padding: 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #f8fafb;
}

.fact-list text {
  display: block;
}

.fact-list text:first-child {
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
}

.fact-list text:last-child {
  margin-top: 6rpx;
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.3;
}

.coach-guide {
  margin-top: 16rpx;
}
