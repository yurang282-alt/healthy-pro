.plan-overview-card {
  padding-bottom: 22rpx;
}

.week-title-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 4rpx;
}

.plan-week-title {
  font-size: 42rpx;
}

.phase-tag {
  min-height: 44rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #eaf4ef;
  color: #157a55;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 30rpx;
}

.plan-brief-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.plan-brief-grid view {
  min-height: 102rpx;
  padding: 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #f8fafb;
}

.plan-brief-grid text {
  display: block;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.35;
}

.plan-brief-grid .brief-value {
  margin-top: 8rpx;
  color: #111827;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.28;
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.week-chip {
  min-height: 86rpx;
  padding: 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
}

.week-chip text {
  display: block;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.35;
}

.week-label {
  margin-top: 4rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.week-chip.active {
  border-color: rgba(21, 122, 85, 0.5);
  background: #eaf4ef;
}

.adjust-explainer {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #fff7e8;
  color: #7a4b11;
  font-size: 24rpx;
  line-height: 1.45;
}

.plan-overview-actions,
.plan-management-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.plan-overview-actions .secondary-button,
.plan-overview-actions .ghost-button,
.plan-management-actions .primary-button,
.plan-management-actions .ghost-button,
.secondary-plan-actions .secondary-button,
.secondary-plan-actions .ghost-button {
  min-height: 64rpx;
  margin-top: 0;
  font-size: 25rpx;
  line-height: 64rpx;
}

.plan-management-card .pill {
  max-width: 190rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-management-card .card-title {
  font-size: 32rpx;
}

.previous-list {
  margin-top: 16rpx;
}

.previous-list .history-row + .history-row {
  margin-top: 12rpx;
}

.workout-stack {
  gap: 14rpx;
}

.workout-card {
  padding: 16rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 16rpx;
  background: #ffffff;
}

.workout-head {
  align-items: center;
}

.workout-title {
  font-size: 32rpx;
}

.workout-summary {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.4;
}

.coach-details-card {
  border-color: rgba(21, 122, 85, 0.18);
}

.coach-note {
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.55;
}

.plan-review {
  margin-top: 16rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.2);
  border-radius: 14rpx;
  background: #f2faf6;
}

.plan-review.warning {
  border-color: rgba(179, 107, 22, 0.28);
  background: #fff7e8;
}

.plan-review > text {
  display: block;
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.plan-review > view {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.review-list {
  display: grid;
  gap: 10rpx;
  margin-top: 12rpx;
}

.review-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr);
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #ffffff;
}

.review-row text:first-child {
  color: #157a55;
  font-weight: 900;
}

.review-row.warning text:first-child {
  color: #b36b16;
}

.review-row text:last-child {
  color: #667085;
  font-size: 23rpx;
  line-height: 1.42;
}

.fact-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.fact-list view {
  min-width: 0;
  padding: 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #f8fafb;
}

.fact-list text {
  display: block;
}

.fact-list text:first-child {
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
}

.fact-list text:last-child {
  margin-top: 6rpx;
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.3;
}

.coach-guide {
  margin-top: 16rpx;
}
