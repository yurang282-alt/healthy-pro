<view class="page">
  <view class="eyebrow">训练记录</view>
  <view class="title">第 {{sessionNumber}} 次训练</view>
  <view class="muted">{{workout.title}} · {{workout.focus}}</view>

  <view wx:if="{{!workout}}" class="card">
    <text class="card-title">先完成基础评估</text>
    <view class="muted">生成训练计划后，这里会变成训练中的逐项记录工具。</view>
    <button class="primary-button" bindtap="goAssessment">开始评估</button>
  </view>

  <view wx:if="{{showCompletionPrompt}}" class="completion-save-pop">
    <view class="completion-copy">
      <text class="completion-kicker">本次训练已完成</text>
      <text class="completion-title">保存本次训练</text>
      <text class="completion-desc">已完成 {{completedCount}} 个动作，保存后会进入历史记录，并用于后续计划调整。</text>
    </view>
    <view class="completion-actions">
      <button class="completion-edit-button" bindtap="dismissCompletionPrompt">继续修改</button>
      <button class="completion-save-button" bindtap="saveLog">保存</button>
    </view>
  </view>

  <view wx:if="{{workout}}" class="card">
    <view class="row">
      <view>
        <view class="eyebrow">本次训练</view>
        <text class="card-title">{{workout.title}}</text>
      </view>
      <view class="session-actions">
        <text class="pill">{{completedCount}}/{{exerciseRecords.length}}</text>
        <button class="small-button draft-button" bindtap="saveDraft">保存草稿</button>
      </view>
    </view>
    <view class="muted session-hint">第 {{sessionNumber}} 次训练 · 第 {{week}} 周 · 按顺序完成，临时离开可保存草稿。</view>

    <view wx:if="{{activeRecord}}" class="training-card">
      <view class="training-progress-line">
        <view style="width: {{activeMeta.progressPercent}}%;"></view>
      </view>
      <view class="record-head active-head">
        <image class="training-visual" src="{{activeRecord.image}}" mode="aspectFit" />
        <view class="item-body">
          <text class="eyebrow">{{activeMeta.indexText}} · {{activeRecord.done ? '已完成' : '待完成'}}</text>
          <text class="card-title">{{activeRecord.name}}</text>
          <text class="item-meta">{{activeRecord.equipmentName}} · {{activeRecord.sets}} · {{activeRecord.reps}}</text>
          <text wx:if="{{activeRecord.load}}" class="load-line">建议起步：{{activeRecord.load}}</text>
        </view>
      </view>

      <view class="training-tip-grid">
        <view>
          <text>吃力程度</text>
          <text>{{activeRecord.effort}}</text>
        </view>
        <view>
          <text>休息</text>
          <text>{{activeRecord.rest}}</text>
        </view>
        <view>
          <text>{{activeRecord.isCardio ? '目标时长' : '当前状态'}}</text>
          <text>{{activeMeta.targetText}}</text>
        </view>
      </view>

      <view class="cue-list">
        <text wx:for="{{activeRecord.cues}}" wx:key="*this">{{item}}</text>
      </view>

      <view wx:if="{{activeRecord.loadDetail}}" class="load-note">{{activeRecord.loadDetail}} {{activeRecord.loadCaution}}</view>
      <button class="small-button detail-button" data-id="{{activeRecord.sourceExerciseId || activeRecord.id}}" bindtap="viewExercise">看动作详情</button>

      <view wx:if="{{activeRecord.isStrength}}" class="record-grid active-field-grid">
        <view class="mini-field">
          <text>重量/档位</text>
          <input type="digit" value="{{activeRecord.weight}}" placeholder="kg" data-index="{{activeExerciseIndex}}" data-key="weight" bindinput="setRecordField" />
        </view>
        <view class="mini-field">
          <text>实际次数</text>
          <input type="text" value="{{activeRecord.actualReps}}" placeholder="12/12/10" data-index="{{activeExerciseIndex}}" data-key="actualReps" bindinput="setRecordField" />
        </view>
      </view>

      <view wx:if="{{activeRecord.isCardio}}" class="record-grid cardio-grid">
        <view class="mini-field">
          <text>时长</text>
          <input type="digit" value="{{activeRecord.durationMinutes}}" placeholder="分钟" data-index="{{activeExerciseIndex}}" data-key="durationMinutes" bindinput="setRecordField" />
        </view>
        <view class="mini-field">
          <text>速度</text>
          <input type="digit" value="{{activeRecord.speed}}" placeholder="5.5" data-index="{{activeExerciseIndex}}" data-key="speed" bindinput="setRecordField" />
        </view>
        <view class="mini-field">
          <text>坡度</text>
          <input type="digit" value="{{activeRecord.incline}}" placeholder="%" data-index="{{activeExerciseIndex}}" data-key="incline" bindinput="setRecordField" />
        </view>
        <view class="mini-field">
          <text>阻力</text>
          <input type="number" value="{{activeRecord.resistance}}" placeholder="档" data-index="{{activeExerciseIndex}}" data-key="resistance" bindinput="setRecordField" />
        </view>
      </view>

      <view wx:if="{{restRemaining}}" class="rest-timer">
        <view>
          <text>组间休息</text>
          <text>{{restRemainingText}}</text>
        </view>
        <button class="small-button" bindtap="skipRest">跳过</button>
      </view>

      <view class="feeling-row">
        <view wx:for="{{feelingChoices}}" wx:for-item="choice" wx:key="value" class="feeling-choice {{activeRecord.feeling == choice.value ? 'active' : ''}}" data-index="{{activeExerciseIndex}}" data-value="{{choice.value}}" bindtap="chooseFeeling">
          <text class="feeling-icon">{{choice.icon}}</text>
          <text class="feeling-label">{{choice.label}}</text>
        </view>
      </view>

      <button wx:if="{{activeRecord.isStrength && !activeRecord.done}}" class="primary-button training-main-button" bindtap="completeActiveStrengthSet">{{activeMeta.actionLabel}}</button>
      <button wx:if="{{activeRecord.isCardio && !activeRecord.done}}" class="primary-button training-main-button" bindtap="completeActiveCardio">{{activeMeta.actionLabel}}</button>
      <view wx:if="{{activeRecord.done}}" class="done-panel">
        <text>这个动作已完成。可以继续修改重量、次数或感觉。</text>
        <button class="small-button" bindtap="markActiveIncomplete">改为待完成</button>
      </view>

      <view class="training-controls">
        <button class="small-button" disabled="{{activeExerciseIndex <= 0}}" bindtap="previousExercise">上一项</button>
        <button class="small-button" disabled="{{activeExerciseIndex >= exerciseRecords.length - 1}}" bindtap="nextExercise">下一项</button>
      </view>

      <view class="training-queue">
        <view class="queue-title">今日动作</view>
        <view wx:for="{{exerciseRecords}}" wx:for-index="recordIndex" wx:key="id" class="queue-item {{recordIndex == activeExerciseIndex ? 'active' : ''}} {{item.done ? 'done' : ''}}" data-index="{{recordIndex}}" bindtap="jumpExercise">
          <text class="queue-index">{{recordIndex + 1}}</text>
          <text class="queue-name">{{item.name}}</text>
          <text class="queue-status">{{item.done ? '已完成' : '待完成'}}</text>
        </view>
      </view>
    </view>

    <view class="field">
      <text class="label">本次整体感觉</text>
      <view class="choice-grid">
        <view class="choice {{intensityFeedback == 'too-easy' ? 'active' : ''}}" data-value="too-easy" bindtap="chooseIntensity">太轻松</view>
        <view class="choice {{intensityFeedback == 'right' ? 'active' : ''}}" data-value="right" bindtap="chooseIntensity">刚刚好</view>
        <view class="choice {{intensityFeedback == 'too-hard' ? 'active' : ''}}" data-value="too-hard" bindtap="chooseIntensity">太吃力</view>
      </view>
    </view>
    <view class="field">
      <text class="label">备注</text>
      <textarea class="textarea" value="{{note}}" bindinput="setNote" placeholder="器械找不到、动作不稳、重量偏轻都可以记这里" />
    </view>
    <button class="primary-button" bindtap="saveLog">{{sessionComplete ? '保存本次训练' : '保存已完成动作'}}</button>
  </view>

  <view class="card">
    <view class="row">
      <view>
        <view class="eyebrow">历史</view>
        <text class="card-title">过去的训练</text>
      </view>
      <text class="pill">{{logs.length}} 次</text>
    </view>
    <view wx:if="{{logs.length}}" class="list">
      <view wx:for="{{logs}}" wx:for-item="log" wx:key="id" class="history-row">
        <view class="item-body">
          <text class="item-title">{{log.sessionLabel}} · {{log.workoutTitle}}</text>
          <text class="item-meta">第 {{log.week}} 周 · {{log.createdLabel}} · {{log.feedbackLabel}} · 完成 {{log.completedCount}} 个动作</text>
          <text wx:if="{{log.completedText}}" class="item-help">完成：{{log.completedText}}</text>
          <view wx:if="{{log.detailLines.length}}" class="history-detail">
            <text wx:for="{{log.detailLines}}" wx:for-item="detail" wx:key="*this">{{detail}}</text>
          </view>
          <view wx:if="{{log.coachFeedbackSummary}}" class="history-coach-feedback">
            <text>{{log.coachFeedbackTitle}}</text>
            <text>{{log.coachFeedbackSummary}}</text>
          </view>
          <text wx:if="{{log.note}}" class="item-help">{{log.note}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="empty-note">还没有历史训练。保存一次训练后会出现在这里。</view>
  </view>

  <view class="card">
    <view class="row">
      <view>
        <view class="eyebrow">身体</view>
        <text class="card-title">身体状态</text>
      </view>
      <text class="pill">可选</text>
    </view>
    <view class="record-grid body-grid">
      <view class="mini-field">
        <text>体重 kg</text>
        <input type="digit" value="{{bodyDraft.weight}}" placeholder="65" data-key="weight" bindinput="setBodyField" />
      </view>
      <view class="mini-field">
        <text>体脂 %</text>
        <input type="digit" value="{{bodyDraft.bodyFat}}" placeholder="14" data-key="bodyFat" bindinput="setBodyField" />
      </view>
      <view class="mini-field">
        <text>睡眠 h</text>
        <input type="digit" value="{{bodyDraft.sleep}}" placeholder="7.5" data-key="sleep" bindinput="setBodyField" />
      </view>
    </view>
    <view class="field">
      <text class="label">身体备注</text>
      <textarea class="textarea body-textarea" value="{{bodyDraft.note}}" data-key="note" bindinput="setBodyField" placeholder="精神状态、酸痛、饮食波动" />
    </view>
    <button class="secondary-button" bindtap="saveBodyLog">保存身体记录</button>

    <view wx:if="{{latestBodyLog}}" class="body-history">
      <text class="item-meta">最近身体记录：{{latestBodyLog.createdLabel}} · {{latestBodyLog.weight}}kg</text>
    </view>
  </view>
</view>
