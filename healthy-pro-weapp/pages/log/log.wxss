.page-kicker {
  color: #176b4d;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.25;
}

.command-subtitle {
  margin-top: 10rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.42;
}

.execution-panel {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background:
    linear-gradient(145deg, rgba(24, 106, 75, 0.7), rgba(17, 24, 39, 0) 52%),
    linear-gradient(315deg, rgba(95, 66, 32, 0.38), rgba(17, 24, 39, 0) 46%),
    #101820;
  box-shadow: 0 30rpx 70rpx rgba(17, 24, 39, 0.22);
}

.execution-head {
  align-items: flex-start;
}

.execution-status {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.4;
}

.execution-pill {
  flex: 0 0 auto;
  min-height: 48rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(215, 247, 229, 0.22);
  border-radius: 999rpx;
  color: #d7f7e5;
  background: rgba(215, 247, 229, 0.1);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.execution-meter {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 22rpx;
}

.execution-meter view {
  min-width: 0;
  padding: 15rpx 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
}

.execution-meter text {
  display: block;
  color: rgba(255, 255, 255, 0.62);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.35;
}

.execution-meter text:last-child {
  margin-top: 5rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 950;
}

.choice-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.choice {
  min-height: 68rpx;
  padding: 14rpx 10rpx;
  font-size: 25rpx;
}

.textarea {
  min-height: 150rpx;
}

.session-hint {
  margin-top: 12rpx;
}

.session-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.draft-button {
  min-height: 54rpx;
  padding: 0 18rpx;
  border-color: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  background: rgba(255, 255, 255, 0.09);
  font-size: 22rpx;
  line-height: 54rpx;
}

.subsection-title {
  margin-top: 22rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.completion-save-pop {
  position: fixed;
  top: 18rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 30;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.28);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 46rpx rgba(15, 23, 42, 0.16);
}

.completion-copy {
  min-width: 0;
  flex: 1;
}

.completion-copy text {
  display: block;
}

.completion-kicker {
  color: #157a55;
  font-size: 21rpx;
  font-weight: 900;
}

.completion-title {
  margin-top: 2rpx;
  color: #111827;
  font-size: 31rpx;
  font-weight: 950;
  line-height: 1.2;
}

.completion-desc {
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 1.35;
}

.completion-actions {
  flex: 0 0 140rpx;
  display: grid;
  gap: 8rpx;
}

.completion-edit-button,
.completion-save-button {
  min-height: 72rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 72rpx;
}

.completion-edit-button {
  border: 1rpx solid #d9e2ec;
  background: #ffffff;
  color: #111827;
}

.completion-save-button {
  background: #111827;
  color: #ffffff;
}

.training-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.13);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.96);
}

.training-progress-line {
  height: 10rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: #edf1f5;
}

.training-progress-line view {
  height: 100%;
  border-radius: 999rpx;
  background: #157a55;
}

.active-head {
  align-items: center;
}

.training-visual {
  flex: 0 0 auto;
  width: 128rpx;
  height: 128rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 16rpx;
  background: #f6f7f8;
}

.training-tip-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.training-tip-grid view {
  min-width: 0;
  padding: 14rpx;
  border: 1rpx solid #dde6ee;
  border-radius: 14rpx;
  background: #f8fafb;
}

.training-tip-grid text {
  display: block;
}

.training-tip-grid text:first-child {
  color: #667085;
  font-size: 21rpx;
  font-weight: 800;
}

.training-tip-grid text:last-child {
  margin-top: 4rpx;
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
}

.status-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.status-tag-row text {
  min-height: 46rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef3f6;
  color: #263241;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 30rpx;
}

.single-cue {
  display: grid;
  gap: 6rpx;
  margin-top: 14rpx;
  padding: 14rpx;
  border-left: 6rpx solid #157a55;
  border-radius: 12rpx;
  background: #eef8f2;
}

.single-cue text:first-child {
  color: #157a55;
  font-size: 21rpx;
  font-weight: 900;
}

.single-cue text:last-child {
  color: #1d3b30;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.38;
}

.inline-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.inline-actions .detail-button {
  margin-top: 0;
}

.detail-drawer {
  margin-top: 12rpx;
}

.cue-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 14rpx;
}

.cue-list text {
  color: #176b4d;
  font-size: 24rpx;
  line-height: 1.38;
}

.load-note {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #fff7ed;
  color: #8a4b0b;
  font-size: 23rpx;
  line-height: 1.4;
}

.active-field-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.rest-timer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #111827;
  color: #ffffff;
}

.rest-timer text {
  display: block;
}

.rest-timer text:first-child {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
}

.rest-timer text:last-child {
  margin-top: 4rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
}

.rest-timer .small-button {
  color: #111827;
  background: #ffffff;
}

.training-main-button {
  margin-top: 16rpx;
}

.done-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 16rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.28);
  border-radius: 14rpx;
  background: #eaf4ef;
}

.done-panel text {
  flex: 1;
  color: #245442;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.35;
}

.done-panel .small-button {
  flex: 0 0 auto;
}

.training-controls {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.training-controls .small-button {
  width: 100%;
}

.training-queue {
  display: grid;
  gap: 10rpx;
  margin-top: 16rpx;
}

.queue-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid rgba(21, 122, 85, 0.24);
  border-radius: 14rpx;
  background: #f2faf6;
}

.queue-toggle text:first-child {
  color: #175d43;
  font-size: 24rpx;
  font-weight: 900;
}

.queue-toggle text:last-child {
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
  text-align: right;
}

.note-toggle {
  border-color: rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.08);
}

.note-toggle text:first-child {
  color: #ffffff;
}

.note-toggle text:last-child {
  color: rgba(255, 255, 255, 0.66);
}

.queue-title {
  color: #157a55;
  font-size: 23rpx;
  font-weight: 900;
}

.queue-item {
  display: grid;
  grid-template-columns: 42rpx 1fr auto;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  min-height: 72rpx;
  padding: 12rpx 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
}

.queue-index {
  color: #667085;
  font-size: 22rpx;
  font-weight: 900;
}

.queue-name {
  overflow: hidden;
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.queue-status {
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #f3f6f8;
  color: #667085;
  font-size: 21rpx;
  font-weight: 900;
}

.queue-item.active {
  border-color: rgba(21, 122, 85, 0.48);
  background: #eaf4ef;
}

.queue-item.done .queue-name {
  color: #157a55;
}

.queue-item.done .queue-status {
  background: #dff1e8;
  color: #157a55;
}

.record-list {
  gap: 18rpx;
}

.compact-field {
  margin-top: 18rpx;
}

.record-card {
  padding: 16rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 16rpx;
  background: #ffffff;
}

.record-card.done {
  border-color: rgba(21, 122, 85, 0.38);
  background: #fbfefd;
}

.history-coach-feedback {
  display: grid;
  gap: 4rpx;
  margin-top: 10rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #eef8f2;
}

.history-coach-feedback text:first-child {
  color: #157a55;
  font-size: 22rpx;
  font-weight: 900;
}

.history-coach-feedback text:last-child {
  color: #245442;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 1.4;
}

.record-head {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.load-line {
  display: block;
  margin-top: 6rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.35;
}

.done-toggle {
  flex: 0 0 auto;
  width: 128rpx;
  min-height: 56rpx;
  margin: 0;
  padding: 0 12rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 999rpx;
  background: #ffffff;
  color: #667085;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 56rpx;
}

.done-toggle.active {
  border-color: rgba(21, 122, 85, 0.4);
  background: #eaf4ef;
  color: #157a55;
}

.record-grid {
  display: grid;
  gap: 10rpx;
  margin-top: 14rpx;
}

.strength-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.cardio-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.body-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.mini-field {
  min-width: 0;
}

.mini-field text {
  display: block;
  margin-bottom: 8rpx;
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
}

.mini-field input {
  width: 100%;
  min-height: 68rpx;
  padding: 12rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 12rpx;
  background: #ffffff;
  color: #111827;
  font-size: 25rpx;
}

.cockpit-feedback-field .label,
.execution-panel .field .label {
  color: rgba(255, 255, 255, 0.86);
}

.cockpit-choice-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.execution-panel .choice {
  border-color: rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.72);
}

.execution-panel .choice.active {
  border-color: rgba(215, 247, 229, 0.42);
  background: rgba(215, 247, 229, 0.15);
  color: #d7f7e5;
}

.execution-panel .textarea {
  border-color: rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.96);
}

.feeling-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 14rpx;
}

.feeling-choice {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  min-width: 0;
  min-height: 72rpx;
  padding: 10rpx 6rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 12rpx;
  background: #ffffff;
  color: #667085;
  font-weight: 900;
  text-align: center;
}

.feeling-code {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: #eef2f5;
  color: #45515f;
  font-size: 18rpx;
  line-height: 34rpx;
}

.feeling-label {
  font-size: 20rpx;
  line-height: 1.15;
}

.feeling-choice.active {
  border-color: rgba(21, 122, 85, 0.48);
  background: #eaf4ef;
  color: #157a55;
}

.feeling-choice.active .feeling-code {
  color: #ffffff;
  background: #157a55;
}

.execution-save-button {
  color: #101820;
  background: #d7f7e5;
}

.after-session-card {
  border-color: rgba(17, 24, 39, 0.08);
  background: #fbfcfd;
}

.history-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 8rpx;
}

.history-detail text {
  color: #667085;
  font-size: 23rpx;
  line-height: 1.35;
}

.body-textarea {
  min-height: 112rpx;
}

.body-history {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #edf1f5;
}

@media (max-width: 360px) {
  .strength-grid,
  .body-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cardio-grid,
  .feeling-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cockpit-choice-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
