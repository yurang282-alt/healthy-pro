.choice-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.choice {
  min-height: 68rpx;
  padding: 14rpx 10rpx;
  font-size: 25rpx;
}

.textarea {
  min-height: 150rpx;
}

.session-hint {
  margin-top: 12rpx;
}

.subsection-title {
  margin-top: 22rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.training-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #d9e2ec;
  border-radius: 18rpx;
  background: #fdfefe;
}

.training-progress-line {
  height: 10rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: #edf1f5;
}

.training-progress-line view {
  height: 100%;
  border-radius: 999rpx;
  background: #157a55;
}

.active-head {
  align-items: center;
}

.training-visual {
  flex: 0 0 auto;
  width: 128rpx;
  height: 128rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 16rpx;
  background: #f6f7f8;
}

.training-tip-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.training-tip-grid view {
  min-width: 0;
  padding: 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #f6f7f8;
}

.training-tip-grid text {
  display: block;
}

.training-tip-grid text:first-child {
  color: #667085;
  font-size: 21rpx;
  font-weight: 800;
}

.training-tip-grid text:last-child {
  margin-top: 4rpx;
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
}

.cue-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 14rpx;
}

.cue-list text {
  color: #176b4d;
  font-size: 24rpx;
  line-height: 1.38;
}

.load-note {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #fff7ed;
  color: #8a4b0b;
  font-size: 23rpx;
  line-height: 1.4;
}

.active-field-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.rest-timer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #111827;
  color: #ffffff;
}

.rest-timer text {
  display: block;
}

.rest-timer text:first-child {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
}

.rest-timer text:last-child {
  margin-top: 4rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
}

.rest-timer .small-button {
  color: #111827;
  background: #ffffff;
}

.training-main-button {
  margin-top: 16rpx;
}

.training-controls {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.training-controls .small-button {
  width: 100%;
}

.training-queue {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  margin-top: 16rpx;
  padding-bottom: 2rpx;
}

.queue-item {
  flex: 0 0 176rpx;
  min-width: 0;
  padding: 12rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
}

.queue-item text {
  display: block;
}

.queue-item text:first-child {
  color: #667085;
  font-size: 22rpx;
  font-weight: 900;
}

.queue-item text:last-child {
  overflow: hidden;
  margin-top: 4rpx;
  color: #111827;
  font-size: 23rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.queue-item.active {
  border-color: rgba(21, 122, 85, 0.48);
  background: #eaf4ef;
}

.queue-item.done text:last-child {
  color: #157a55;
}

.record-list {
  gap: 18rpx;
}

.record-card {
  padding: 16rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 16rpx;
  background: #ffffff;
}

.record-card.done {
  border-color: rgba(21, 122, 85, 0.38);
  background: #fbfefd;
}

.history-coach-feedback {
  display: grid;
  gap: 4rpx;
  margin-top: 10rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #eef8f2;
}

.history-coach-feedback text:first-child {
  color: #157a55;
  font-size: 22rpx;
  font-weight: 900;
}

.history-coach-feedback text:last-child {
  color: #245442;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 1.4;
}

.record-head {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.load-line {
  display: block;
  margin-top: 6rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.35;
}

.done-toggle {
  flex: 0 0 auto;
  width: 128rpx;
  min-height: 56rpx;
  margin: 0;
  padding: 0 12rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 999rpx;
  background: #ffffff;
  color: #667085;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 56rpx;
}

.done-toggle.active {
  border-color: rgba(21, 122, 85, 0.4);
  background: #eaf4ef;
  color: #157a55;
}

.record-grid {
  display: grid;
  gap: 10rpx;
  margin-top: 14rpx;
}

.strength-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.cardio-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.body-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.mini-field {
  min-width: 0;
}

.mini-field text {
  display: block;
  margin-bottom: 8rpx;
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
}

.mini-field input {
  width: 100%;
  min-height: 68rpx;
  padding: 12rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 12rpx;
  background: #ffffff;
  color: #111827;
  font-size: 25rpx;
}

.feeling-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 14rpx;
}

.feeling-choice {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  min-width: 0;
  min-height: 68rpx;
  padding: 10rpx 6rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 12rpx;
  background: #ffffff;
  color: #667085;
  font-weight: 900;
  text-align: center;
}

.feeling-icon {
  font-size: 24rpx;
  line-height: 1;
}

.feeling-label {
  font-size: 20rpx;
  line-height: 1.15;
}

.feeling-choice.active {
  border-color: rgba(21, 122, 85, 0.48);
  background: #eaf4ef;
  color: #157a55;
}

.history-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 8rpx;
}

.history-detail text {
  color: #667085;
  font-size: 23rpx;
  line-height: 1.35;
}

.body-textarea {
  min-height: 112rpx;
}

.body-history {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #edf1f5;
}

@media (max-width: 360px) {
  .strength-grid,
  .body-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cardio-grid,
  .feeling-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
