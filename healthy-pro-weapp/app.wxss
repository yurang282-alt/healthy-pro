page {
  min-height: 100%;
  background: #f7f8fa;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  margin-left: 0;
  margin-right: 0;
  padding: 0 24rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(136rpx + env(safe-area-inset-bottom));
}

.eyebrow {
  color: #157a55;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.3;
}

.title {
  margin-top: 6rpx;
  color: #111827;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.08;
}

.muted {
  color: #667085;
  font-size: 26rpx;
  line-height: 1.46;
}

.card {
  margin-top: 20rpx;
  padding: 22rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 18rpx;
  background: #ffffff;
}

.dark-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #111827;
  color: #ffffff;
}

.dark-card .muted,
.dark-card .eyebrow {
  color: rgba(255, 255, 255, 0.72);
}

.card-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.dark-card .card-title {
  color: #ffffff;
}

.section-title {
  margin-top: 34rpx;
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.plan-chip {
  flex: 0 0 auto;
  min-height: 44rpx;
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  color: #175d43;
  background: #eef8f2;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 28rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.metric {
  min-width: 0;
  padding: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.08);
}

.metric text {
  display: block;
  color: rgba(255, 255, 255, 0.66);
  font-size: 22rpx;
}

.metric-value {
  display: block;
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.light-metric {
  border-color: #e1e7ee;
  background: #f6f7f8;
}

.light-metric text {
  color: #667085;
}

.light-metric .metric-value {
  color: #111827;
}

.primary-button,
.secondary-button,
.ghost-button {
  width: 100%;
  min-height: 88rpx;
  margin-top: 18rpx;
  border-radius: 14rpx;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 88rpx;
}

.small-button {
  width: auto;
  min-height: 72rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
  color: #111827;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 72rpx;
}

.detail-button {
  width: auto;
  min-height: 64rpx;
  margin-top: 10rpx;
  padding: 0 18rpx;
  border-color: rgba(21, 122, 85, 0.28);
  color: #157a55;
  background: #f2faf6;
  font-size: 24rpx;
  line-height: 64rpx;
}

.primary-button {
  color: #ffffff;
  background: #111827;
}

.secondary-button {
  color: #157a55;
  border: 1rpx solid rgba(21, 122, 85, 0.3);
  background: #eaf4ef;
}

.ghost-button {
  color: #111827;
  border: 1rpx solid #e1e7ee;
  background: #ffffff;
}

.dark-card .primary-button {
  color: #111827;
  background: #ffffff;
}

.action-row {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.action-row .primary-button,
.action-row .secondary-button,
.action-row .ghost-button {
  flex: 1;
  min-width: 0;
  margin-top: 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 16rpx;
}

.exercise-row,
.equipment-row,
.history-row {
  display: flex;
  gap: 14rpx;
  padding: 14rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
}

.thumb {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 12rpx;
  background: #f6f7f8;
}

.item-body {
  min-width: 0;
  flex: 1;
}

.item-title {
  display: block;
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
}

.item-meta {
  display: block;
  margin-top: 6rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.4;
}

.item-help {
  display: block;
  margin-top: 6rpx;
  color: #176b4d;
  font-size: 25rpx;
  line-height: 1.42;
}

.pill {
  flex: 0 0 auto;
  min-height: 44rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #0f3d2d;
  background: #eaf4ef;
  font-size: 24rpx;
  font-weight: 900;
}

.form {
  margin-top: 24rpx;
}

.field {
  margin-top: 22rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.input,
.textarea {
  width: 100%;
  min-height: 80rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
  color: #111827;
  font-size: 28rpx;
}

.textarea {
  min-height: 124rpx;
}

.choice-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.choice {
  min-height: 84rpx;
  padding: 16rpx;
  border: 1rpx solid #e1e7ee;
  border-radius: 14rpx;
  background: #ffffff;
  color: #667085;
  font-size: 27rpx;
  font-weight: 900;
  text-align: center;
}

.choice.active {
  border-color: rgba(21, 122, 85, 0.5);
  background: #eaf4ef;
  color: #157a55;
}

.empty-note {
  margin-top: 16rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}
